<?xml version="1.0" encoding="utf-8"?>
<selector android:exitFadeDuration="200"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="@color/primary" android:endColor="@color/primary" android:angle="90.0" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="5.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="5.0dp" />
            <stroke android:width="2.0dp" android:color="@color/primary" />
        </shape>
    </item>
    <item android:state_hovered="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="@color/primary" android:endColor="@color/primary" android:angle="90.0" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="5.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="5.0dp" />
            <stroke android:width="2.0dp" android:color="@color/primary" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="@color/primary" android:endColor="@color/primary" android:angle="90.0" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="5.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="5.0dp" />
            <stroke android:width="2.0dp" android:color="@color/primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="@color/primary" android:endColor="@color/primary" android:angle="90.0" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="5.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="5.0dp" />
            <stroke android:width="2.0dp" android:color="@color/primary" />
        </shape>
    </item>
</selector>
