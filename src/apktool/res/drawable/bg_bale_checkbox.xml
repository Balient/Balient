<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="?n20" />
            <padding android:left="1.5dp" android:top="1.5dp" android:right="1.5dp" android:bottom="1.5dp" />
        </shape>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="?n20" />
                </shape>
            </item>
            <item android:left="2.0dp" android:top="2.0dp" android:right="2.0dp" android:bottom="2.0dp">
                <shape android:shape="oval">
                    <stroke android:width="1.5dp" android:color="?colorPrimary" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
